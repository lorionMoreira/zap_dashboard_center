# API Configuration
VITE_API_URL=http://localhost:8087/api

# Required by backend for auth endpoints
# Example: 404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
VITE_AUTH_BEARER_TOKEN=

# Set to 'true' to use mock authentication (no backend required)
# Set to 'false' when connecting to a real API
VITE_MOCK_AUTH=false
